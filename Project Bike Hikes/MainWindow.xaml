<Window x:Class="Project_Bike_Hikes.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:Project_Bike_Hikes"
            mc:Ignorable="d"
            Title="Bike Ride"
            Loaded="Window_Loaded_1"
            WindowState="Maximized" 
            WindowStyle="SingleBorderWindow"
            AllowsTransparency="False"
            Background="Transparent" Height="1091" Width="1927"
>
    <Viewbox>
        <Grid>
            <MediaElement Name="BackgroundVideo"
                      Source="Ressource/VideoBike3.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="Fill"
                      IsHitTestVisible="False"
                      IsMuted="True"
                      MediaEnded="BackgroundVideo_MediaEnded" Margin="0,0,-225,-176"/>

            <ComboBox x:Name="LangBox" HorizontalAlignment="Left" Height="25" Margin="10,10,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="LangBox_SelectionChanged"/>
            <TextBlock x:Name="LangText" HorizontalAlignment="Left" Height="29" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" FontSize="20" FontFamily="Sitka Banner" Foreground="Black" RenderTransformOrigin="0.483,0.706" Margin="21,10,0,0"><Run Text="Country : "/></TextBlock>


            <Grid HorizontalAlignment="Center" Height="175" VerticalAlignment="Top" Width="676" RenderTransformOrigin="0.497,0.469">
                <TextBlock x:Name="MainTitle" HorizontalAlignment="Left" Height="72" TextWrapping="Wrap" VerticalAlignment="Top" Width="270" FontSize="60" FontFamily="Sitka Banner" Foreground="White" RenderTransformOrigin="0.483,0.706" Margin="202,-4,0,0"><Run Text="BIKE "/><Run Language="en-gb" Text="R"/><Run Text="I"/><Run Language="en-gb" Text="D"/><Run Text="E"/></TextBlock>
                <TextBlock x:Name="Filtred_Box" HorizontalAlignment="Left" Height="21" Margin="269,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="108" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" FontSize="16"><Run Text="Filtered ride by "/><Run Language="en-gb" Text=":"/></TextBlock>
                <TextBlock x:Name="Filtre1" HorizontalAlignment="Left" Height="21" Margin="86,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848"><Run Text="Difficulty "/><Run Language="en-gb" Text=":"/></TextBlock>
                <TextBlock x:Name="Filtred2" HorizontalAlignment="Left" Height="21" Margin="219,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="102" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848"><Run Text="Best Weather "/><Run Language="en-gb" Text=":"/></TextBlock>
                <TextBlock x:Name="Filtred3" HorizontalAlignment="Left" Height="21" Margin="349,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848"><Run Text="Optimal Bike "/><Run Language="en-gb" Text=":"/></TextBlock>
                <TextBlock x:Name="Filtred4" HorizontalAlignment="Left" Height="21" Margin="476,87,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848"><Run Text="Corwds "/><Run Language="en-gb" Text=":"/></TextBlock>
                <ComboBox x:Name="DiffBox" HorizontalAlignment="Left" Height="25" Margin="86,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged"/>
                <ComboBox x:Name="DiffBox_Copy" HorizontalAlignment="Left" Height="25" Margin="349,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066"/>
                <ComboBox x:Name="DiffBox_Copy1" HorizontalAlignment="Left" Height="26" Margin="219,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.268,0.801"/>
                <ComboBox x:Name="DiffBox_Copy3" HorizontalAlignment="Left" Height="25" Margin="476,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066"/>
            </Grid>



            <Grid HorizontalAlignment="Center" Height="271" VerticalAlignment="Center" Width="696" RenderTransformOrigin="0.49,0.504">
                <TextBlock HorizontalAlignment="Left" Margin="11,27,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="143" FontSize="18" RenderTransformOrigin="0.5,0.5" FontStyle="Italic" FontFamily="Sitka Banner" Foreground="White" Background="#66484848">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="1.442"/>
                            <RotateTransform/>
                            <TranslateTransform X="0.73"/>
                        </TransformGroup>
                    </TextBlock.RenderTransform><Run Text="Best Match"/><Run Language="en-gb" Text=" "/><Run Text="Found :"/></TextBlock>
                <ListBox x:Name="BestMatchListBox" HorizontalAlignment="Left" Height="201" Margin="12,64,0,0" VerticalAlignment="Top" Width="389" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33808080" Foreground="White" SelectionChanged="BestMatchListBox_SelectionChanged"    />
                <TextBlock HorizontalAlignment="Left" Margin="442,28,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="18" FontStyle="Italic" FontFamily="Sitka Banner" Width="137" Foreground="White" Background="#66484848"><Run Text="Trending Ride"/><Run Language="en-gb" Text=" :"/></TextBlock>
                <ListBox x:Name="Trending" HorizontalAlignment="Left" Height="201" Margin="441,64,0,0" VerticalAlignment="Top" Width="245" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33FFFFFF" Foreground="White" SelectionChanged="Trending_SelectionChanged" />
            </Grid>
        </Grid>
    </Viewbox>
</Window>