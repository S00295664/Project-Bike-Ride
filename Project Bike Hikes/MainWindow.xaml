<Window x:Class="Project_Bike_Hikes.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:Project_Bike_Hikes"
            mc:Ignorable="d"
            Title="Bike Ride"
            Loaded="Window_Loaded_1"
            WindowState="Maximized" 
            WindowStyle="SingleBorderWindow"
            AllowsTransparency="False"
            Background="Transparent" Height="1091" Width="1927">
    <Viewbox>
        <Grid>
            <MediaElement Name="BackgroundVideo"
                      Source="Ressource/VideoBike3.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="Fill"
                      IsHitTestVisible="False"
                      IsMuted="True"
                      MediaEnded="BackgroundVideo_MediaEnded" Margin="0,0,-225,-176"/>
            <ComboBox x:Name="LangBox" HorizontalAlignment="Left" Height="25" Margin="10,11,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="LangBox_SelectionChanged"/>
            <Button HorizontalAlignment="Left" Height="82" Margin="10,34,0,0" VerticalAlignment="Top" Width="104" Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click" BorderBrush="#00707070">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <Image Source="/Ressource/helmet.png" Width="97" Height="69"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="LangText" HorizontalAlignment="Left" Height="29" TextWrapping="Wrap" VerticalAlignment="Top" Width="64" FontSize="18" FontFamily="Sitka Banner" Foreground="Black" RenderTransformOrigin="0.483,0.706" Margin="17,11,0,0" Text="Country : "/>
            <Grid HorizontalAlignment="Center" Height="175" VerticalAlignment="Top" Width="676" RenderTransformOrigin="0.497,0.469">
                <TextBlock x:Name="MainTitle" HorizontalAlignment="Left" Height="72" TextWrapping="Wrap" VerticalAlignment="Top" Width="270" FontSize="60" FontFamily="Sitka Banner" Foreground="White" RenderTransformOrigin="0.483,0.706" Margin="202,-4,0,0" Text="BIKE RIDE"/>
                <TextBlock x:Name="Filtred_Box" HorizontalAlignment="Left" Height="21" Margin="269,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="108" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" FontSize="16" Text="Filter ride by "/>
                <TextBlock x:Name="Filtre1" HorizontalAlignment="Left" Height="21" Margin="86,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848"  Text="Difficulty "/>
                <TextBlock x:Name="Filtred2" HorizontalAlignment="Left" Height="21" Margin="219,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="102" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848" Text="Typical Weather "/>
                <TextBlock x:Name="Filtred3" HorizontalAlignment="Left" Height="21" Margin="349,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848" Text="Best bike :"/>
                <TextBlock x:Name="Filtred4" HorizontalAlignment="Left" Height="21" Margin="476,87,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" Background="#66484848" Text="Crowds :"/>
                <ComboBox x:Name="DiffBox" HorizontalAlignment="Left" Height="25" Margin="86,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged"/>
                <ComboBox x:Name="DiffBox_Copy" HorizontalAlignment="Left" Height="25" Margin="349,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066"/>
                <ComboBox x:Name="DiffBox_Copy1" HorizontalAlignment="Left" Height="26" Margin="219,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.268,0.801"/>
                <ComboBox x:Name="DiffBox_Copy3" HorizontalAlignment="Left" Height="25" Margin="476,109,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066"/>
            </Grid>
            <Grid HorizontalAlignment="Center" Height="400" VerticalAlignment="Top" Width="696" RenderTransformOrigin="0.49,0.504" Margin="0,117,0,0">
                <TextBlock HorizontalAlignment="Left" Margin="11,39,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="109" FontSize="18" RenderTransformOrigin="0.5,0.5" FontStyle="Italic" FontFamily="Sitka Banner" Foreground="White" Background="#66484848" Text="Best Match :">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="1.442"/>
                            <RotateTransform/>
                            <TranslateTransform X="0.73"/>
                        </TransformGroup>
                    </TextBlock.RenderTransform></TextBlock>
                <ListBox x:Name="BestMatchListBox" HorizontalAlignment="Left" Height="201" Margin="12,64,0,0" VerticalAlignment="Top" Width="389" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33808080" Foreground="White" SelectionChanged="BestMatchListBox_SelectionChanged"    />
                <ListBox x:Name="History" HorizontalAlignment="Left" Height="81" Margin="12,293,0,0" VerticalAlignment="Top" Width="389" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33808080" Foreground="White" SelectionChanged="his_SelectionChanged"    />
                <TextBlock HorizontalAlignment="Left" Margin="12,270,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="18" FontStyle="Italic" FontFamily="Sitka Banner" Width="84" Foreground="White" Background="#66484848" Text="History :"/>
                <TextBlock HorizontalAlignment="Left" Margin="441,311,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="18" FontStyle="Italic" FontFamily="Sitka Banner" Width="206" Foreground="White" Background="#66B05454" Text="Want to see your favorite ?            Check your profile     (top left)"/>
                <Image Source="/Ressource/heart.png" Margin="619,303,27,69" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="21.36"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <TextBlock HorizontalAlignment="Left" Margin="441,41,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="18" FontStyle="Italic" FontFamily="Sitka Banner" Width="137" Foreground="White" Background="#66484848" Text="Trending rides"/>
                <ListBox x:Name="Trending" HorizontalAlignment="Left" Height="201" Margin="441,64,0,0" VerticalAlignment="Top" Width="245" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33FFFFFF" Foreground="White" SelectionChanged="Trending_SelectionChanged" />
            </Grid>
        </Grid>
    </Viewbox>
</Window>