<Window x:Class="Project_Bike_Hikes.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:Project_Bike_Hikes"
            mc:Ignorable="d"
            Title="Bike Ride"
            Loaded="Window_Loaded_1"
            WindowState="Maximized" 
            WindowStyle="SingleBorderWindow"
            AllowsTransparency="False"
            Background="Transparent" Height="933" Width="1658"
>
    <Grid>
        <MediaElement Name="BackgroundVideo"
                      Source="Ressource/VideoBike3.mp4"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="Fill"
                      IsHitTestVisible="False"
                      IsMuted="True"
                      MediaEnded="BackgroundVideo_MediaEnded" Margin="0,0,-105,0"/>
        <Viewbox HorizontalAlignment="Left" Height="399" Margin="322,10,0,0" VerticalAlignment="Top" Width="1203">
            <Grid HorizontalAlignment="Center" Height="174" VerticalAlignment="Top" Width="580" RenderTransformOrigin="0.497,0.469">
                <TextBlock x:Name="MainTitle" HorizontalAlignment="Left" Height="56" TextWrapping="Wrap" VerticalAlignment="Top" Width="212" FontSize="48" FontFamily="Sitka Banner" Foreground="White" RenderTransformOrigin="0.483,0.706" Margin="217,10,0,0"><Run Text="BIKE "/><Run Language="en-gb" Text="R"/><Run Text="I"/><Run Language="en-gb" Text="D"/><Run Text="E"/></TextBlock>
                <TextBlock x:Name="Filtred_Box" HorizontalAlignment="Left" Height="21" Margin="269,61,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="108" FontStyle="Italic" RenderTransformOrigin="1.534,7.215" FontFamily="Sitka Banner" Foreground="White" FontSize="16"><Run Text="Filtered ride by "/><Run Language="en-gb" Text=":"/></TextBlock>
                <ComboBox x:Name="DiffBox" HorizontalAlignment="Left" Height="25" Margin="97,87,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" Grid.ColumnSpan="2"/>
                <ComboBox x:Name="DiffBox_Copy" HorizontalAlignment="Left" Height="25" Margin="343,87,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066" Grid.ColumnSpan="2"/>
                <ComboBox x:Name="DiffBox_Copy1" HorizontalAlignment="Left" Height="26" Margin="217,86,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.268,0.801" Grid.ColumnSpan="2"/>
                <ComboBox x:Name="DiffBox_Copy3" HorizontalAlignment="Left" Height="25" Margin="468,87,0,0" VerticalAlignment="Top" Width="104" SelectionChanged="DiffBox_SelectionChanged" RenderTransformOrigin="1.628,3.066" Grid.ColumnSpan="2"/>
            </Grid>
        </Viewbox>

        <Viewbox HorizontalAlignment="Left" Height="634" Margin="181,261,0,0" VerticalAlignment="Top" Width="1472" RenderTransformOrigin="0.5,0.5">
            <Viewbox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.012"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Viewbox.RenderTransform>
            <Grid HorizontalAlignment="Center" Height="258" VerticalAlignment="Center" Width="696" RenderTransformOrigin="0.49,0.504">
                <TextBlock HorizontalAlignment="Left" Margin="6,12,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="143" FontSize="18" RenderTransformOrigin="0.5,0.5" FontStyle="Italic" FontFamily="Sitka Banner" Foreground="White" Background="#66484848">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="1.442"/>
                            <RotateTransform/>
                            <TranslateTransform X="0.73"/>
                        </TransformGroup>
                    </TextBlock.RenderTransform><Run Text="Best Match"/><Run Language="en-gb" Text=" "/><Run Text="Found :"/></TextBlock>
                <ListBox x:Name="BestMatchListBox" HorizontalAlignment="Left" Height="201" Margin="7,49,0,0" VerticalAlignment="Top" Width="389" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33808080" Foreground="White" SelectionChanged="BestMatchListBox_SelectionChanged"    />
                <TextBlock HorizontalAlignment="Left" Margin="437,13,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="18" FontStyle="Italic" FontFamily="Sitka Banner" Width="137" Foreground="White" Background="#66484848"><Run Text="Trending Ride"/><Run Language="en-gb" Text=" :"/></TextBlock>
                <ListBox x:Name="Trending" HorizontalAlignment="Left" Height="201" Margin="436,49,0,0" VerticalAlignment="Top" Width="221" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#33FFFFFF" Foreground="White" SelectionChanged="Trending_SelectionChanged" />
            </Grid>
        </Viewbox>
    </Grid>
</Window>