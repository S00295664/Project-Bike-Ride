<Window x:Class="Project_Bike_Hikes.RidePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Bike_Hikes"
        mc:Ignorable="d"
        Title="RidePage" 
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="Black"
        Height="933" Width="1630">

    <Grid>

        <Image Source="/Ressource/5840199.jpg" Stretch="UniformToFill" Panel.ZIndex="0"/>


        <Viewbox Stretch="Uniform" Panel.ZIndex="1"
         HorizontalAlignment="Left"
         VerticalAlignment="Top">
            <Grid Width="1630" Height="933">
                <Button HorizontalAlignment="Left" Height="124" Margin="10,10,0,0" VerticalAlignment="Top" Width="164"
                        Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click" BorderBrush="#00707070">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Ressource/home.png" Width="155" Height="92"/>
                    </StackPanel>
                </Button>

                <TextBox x:Name="RideName" HorizontalAlignment="Center" Height="191" IsHitTestVisible="False"
                         Margin="0,38,0,0" TextWrapping="Wrap" IsReadOnly="True" Text="TextBox"
                         VerticalAlignment="Top" Width="614" TextChanged="TextBox_TextChanged"
                         Background="Transparent" FontSize="72" Foreground="White"
                         BorderBrush="#00ABADB3" FontFamily="Sitka Banner" TextAlignment="Center"/>

                <TextBox x:Name="BikeType" HorizontalAlignment="Left" Height="98" IsHitTestVisible="False"
                         Margin="39,297,0,0" TextWrapping="Wrap" Text="TextBox" IsReadOnly="True"
                         VerticalAlignment="Top" Width="661" Background="Transparent"
                         FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                         TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3"/>

                <Image x:Name="MapPreview" Stretch="Uniform" Margin="1238,554,77,68"
                       Initialized="MapPreview_Initialized"/>
            </Grid>
        </Viewbox>
    </Grid>
</Window>