<Window x:Class="Project_Bike_Hikes.RidePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Bike_Hikes"
        mc:Ignorable="d"
        Title="RidePage" 
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="Transparent" Height="933" Width="1658">
    <Grid>

        <MediaElement Name="BackgroundVideo"
              Source="Ressource/VideoBike3.mp4"
              LoadedBehavior="Manual"
              UnloadedBehavior="Manual"
              Stretch="Fill"
              IsHitTestVisible="False"
              IsMuted="True"
              MediaEnded="BackgroundVideo_MediaEnded" Margin="0,0,-105,0"/>

        <Button Content="Button" HorizontalAlignment="Left" Height="85" Margin="39,38,0,0" VerticalAlignment="Top" Width="141" Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click"/>
        <TextBox x:Name="RideName" HorizontalAlignment="Left" Height="197" Margin="618,459,0,0" TextWrapping="Wrap" IsReadOnly="True" Text="TextBox" VerticalAlignment="Top" Width="445" TextChanged="TextBox_TextChanged" Background="Transparent" FontSize="48" Foreground="White"/>

    </Grid>
</Window>
