<Window x:Class="Project_Bike_Hikes.RidePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Bike_Hikes"
        mc:Ignorable="d"
        Title="RidePage" 
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="Transparent" Height="933" Width="1658">
    <Viewbox>
        <Grid>

            <Image Source="/Ressource/5840199.jpg" Stretch="UniformToFill" Panel.ZIndex="0" />
            <Button  HorizontalAlignment="Left" Height="304" Margin="39,38,0,0" VerticalAlignment="Top" Width="321" Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Ressource/bike icon.png" Width="319" Height="398"/>
                </StackPanel>
            </Button>

            <TextBox x:Name="RideName" HorizontalAlignment="Center" Height="332" IsHitTestVisible="False" Margin="0,38,0,0" TextWrapping="Wrap" IsReadOnly="True" Text="TextBox" VerticalAlignment="Top" Width="1161" TextChanged="TextBox_TextChanged" Background="Transparent" FontSize="100" Foreground="White" BorderBrush="#00ABADB3" FontFamily="Sitka Banner" TextAlignment="Center"/>
            <TextBox x:Name="BikeType" HorizontalAlignment="Left" Height="65" IsHitTestVisible="False" Margin="103,680,0,0" TextWrapping="Wrap" Text="TextBox" IsReadOnly="True" VerticalAlignment="Top" Width="919" Background="Transparent" FontFamily="Sitka Banner" FontSize="72" Foreground="#FFF9F9F9" TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3"/>
            <Image x:Name="MapPreview" Stretch="Uniform" Margin="1238,554,77,68" Initialized="MapPreview_Initialized"/>

        </Grid>
    </Viewbox>
</Window>
