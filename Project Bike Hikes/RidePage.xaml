<Window x:Class="Project_Bike_Hikes.RidePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Bike_Hikes"
        mc:Ignorable="d"
        Title="RidePage" 
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="Black"
        Height="933" Width="1630">

    <Grid>


        <Image Source="/Ressource/cyclist1.jpg" Stretch="UniformToFill" Panel.ZIndex="0" />


        <Viewbox Stretch="Uniform" Panel.ZIndex="1"
         HorizontalAlignment="Left"
         VerticalAlignment="Center">
            <Grid Width="1630" Height="933">
                <Button HorizontalAlignment="Left" Height="124" Margin="10,10,0,0" VerticalAlignment="Top" Width="164"
                        Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click" BorderBrush="#00707070">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Ressource/home.png" Width="155" Height="92"/>
                    </StackPanel>
                </Button>
                <Image Source="/Ressource/down.png"  Margin="344,457,1108,273" RenderTransformOrigin="0.5,0.5" >
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-89.612"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <TextBox x:Name="RideName" HorizontalAlignment="Left" Height="96" IsHitTestVisible="False"
                         Margin="414,38,0,0" TextWrapping="Wrap" IsReadOnly="True" Text="TextBox"
                         VerticalAlignment="Top" Width="902" TextChanged="TextBox_TextChanged"
                         Background="#330A0A0A" FontSize="72" Foreground="White"
                         BorderBrush="#00ABADB3" FontFamily="Sitka Banner" TextAlignment="Center"/>

                <TextBox x:Name="BikeType" HorizontalAlignment="Left" Height="59" IsHitTestVisible="False"
                         Margin="128,623,0,0" TextWrapping="Wrap" Text="BikeType" IsReadOnly="True"
                         VerticalAlignment="Top" Width="661" Background="Transparent"
                         FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                         TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3"/>
                <TextBox x:Name="Description" HorizontalAlignment="Left" Height="189" IsHitTestVisible="False"
                         Margin="128,247,0,0" TextWrapping="Wrap" Text="Description" IsReadOnly="True"
                         VerticalAlignment="Top" Width="1108" Background="Transparent"
                         FontFamily="Sitka Banner" FontSize="24" Foreground="#FFF9F9F9"
                         TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="Description_Initialized"/>
                <TextBox x:Name="City1" HorizontalAlignment="Left" Height="60" IsHitTestVisible="False"
                        Margin="128,536,0,0" TextWrapping="Wrap" Text="TextBox" IsReadOnly="True"
                        VerticalAlignment="Top" Width="259" Background="#00000000"
                        FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                        TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="City_Initialized1"/>
                <TextBox x:Name="Score" IsHitTestVisible="False"
                        Margin="134,838,1202,41" TextWrapping="Wrap" Text="Score" IsReadOnly="True" Background="#00000000"
                        FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                        TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="Score_Init"/>
                <ProgressBar x:Name="ScoreBar" Minimum="0" Maximum="10"  Margin="391,848,291,51" Initialized="ScoreBar_Initialized_1" />



                <TextBox x:Name="City2" HorizontalAlignment="Left" Height="60" IsHitTestVisible="False"
                        Margin="611,536,0,0" TextWrapping="Wrap" Text="TextBox" IsReadOnly="True"
                        VerticalAlignment="Top" Width="414" Background="#00000000"
                        FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                        TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="City_Initialized2"/>
                <TextBox x:Name="Weather" HorizontalAlignment="Left" Height="61" IsHitTestVisible="False"
                        Margin="128,682,0,0" TextWrapping="Wrap" Text="Average Weather :" IsReadOnly="True"
                        VerticalAlignment="Top" Width="600" Background="Transparent"
                        FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9"
                        TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="Weather_Initialized"/>
                <TextBox x:Name="tESnO" HorizontalAlignment="Left" Height="61" IsHitTestVisible="False"
            Margin="611,848,0,0" TextWrapping="Wrap" Text="No                                                                                Yes" IsReadOnly="True"
            VerticalAlignment="Top" Width="600" Background="Transparent"
            FontFamily="Sitka Banner" FontSize="24" Foreground="Black"
            TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3" Initialized="Weather_Initialized"/>

            </Grid>
        </Viewbox>
    </Grid>
</Window>