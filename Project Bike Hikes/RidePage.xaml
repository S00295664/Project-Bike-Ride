<Window x:Class="Project_Bike_Hikes.RidePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Bike_Hikes"
        mc:Ignorable="d"
        Title="RidePage" 
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="Transparent" Height="933" Width="1658">
    
        <Grid>
        
            <Image Source="/Ressource/5840199.jpg" Stretch="UniformToFill" Panel.ZIndex="0" />
            <Button  HorizontalAlignment="Left" Height="85" Margin="39,38,0,0" VerticalAlignment="Top" Width="141" Background="#00DDDDDD" Foreground="White" FontSize="18" Click="Button_Click">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="/Ressource/bike icon.png" Width="132" Height="105"/>
            </StackPanel>
            </Button>
            <TextBox x:Name="RideName" HorizontalAlignment="Left" Height="85" IsHitTestVisible="False" Margin="584,38,0,0" TextWrapping="Wrap" IsReadOnly="True" Text="TextBox" VerticalAlignment="Top" Width="729" TextChanged="TextBox_TextChanged" Background="Transparent" FontSize="72" Foreground="White" BorderBrush="#00ABADB3" FontFamily="Sitka Banner" TextAlignment="Center"/>
            <TextBox x:Name="BikeType" HorizontalAlignment="Left" Height="65" IsHitTestVisible="False" Margin="110,277,0,0" TextWrapping="Wrap" Text="TextBox" IsReadOnly="True" VerticalAlignment="Top" Width="919" Background="Transparent" FontFamily="Sitka Banner" FontSize="36" Foreground="#FFF9F9F9" TextChanged="BIKE_TextChanged" BorderBrush="#00ABADB3"/>
            
        </Grid>
    
</Window>
